{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury handloom product",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Short craftsmanship story" },
        "price": { "type": "number", "description": "Product price" },
        "imageUrls": { "type": "array", "items": { "type": "string" }, "description": "URLs of the product images from different angles" },
        "category": { "type": "string", "description": "Product category" },
        "collection": { "type": "string", "description": "Product collection" },
        "craftStory": { "type": "string", "description": "Detailed story of the craft" },
        "materialDetails": { "type": "string", "description": "Details about the materials used" },
        "careInstructions": { "type": "string", "description": "How to care for the textile" },
        "sku": { "type": "string", "description": "Stock Keeping Unit" },
        "tagline": { "type": "string", "description": "Product tagline" },
        "fitType": { "type": "string", "description": "Fit type (e.g., Regular, Relaxed)" },
        "packageContent": { "type": "string", "description": "What is included in the package" },
        "sizes": { "type": "array", "items": { "type": "string" }, "description": "Available sizes" },
        "isFeatured": { "type": "boolean", "description": "Whether the product is featured on the home page" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "price", "imageUrls", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerEmail", "items", "totalAmount", "status"]
    },
    "User": {
      "title": "User",
      "description": "Application user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["email", "role"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A curated collection of products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Customer feedback",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "content": { "type": "string" },
        "location": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "content"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "UserActivity": {
      "title": "User Activity",
      "description": "User browsing history and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "viewedProductIds": { "type": "array", "items": { "type": "string" } },
        "preferredCategories": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "viewedProductIds", "preferredCategories", "updatedAt"]
    },
    "PageContent": {
      "title": "Page Content",
      "description": "Stores content for static pages like About, Craft, and Contact",
      "type": "object",
      "properties": {
        "pageId": { "type": "string", "description": "Identifier for the page (e.g., 'about', 'craft')" },
        "title": { "type": "string", "description": "Main title of the page" },
        "subtitle": { "type": "string", "description": "Subtitle or hero text" },
        "heroImageUrl": { "type": "string", "description": "URL of the hero image" },
        "content": { "type": "string", "description": "Main text content" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "content": { "type": "string" },
              "imageUrl": { "type": "string" },
              "imagePosition": { "type": "string", "enum": ["left", "right"] }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pageId", "title", "updatedAt"]
    },
    "HeroSlide": {
      "title": "Hero Slide",
      "description": "An image for the home page hero slider",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "order": { "type": "number", "description": "Display order" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl"]
    },
    "CollectionSlide": {
      "title": "Collection Slide",
      "description": "A featured collection showcase slide on the home page",
      "type": "object",
      "properties": {
        "collectionName": { "type": "string", "description": "E.g. Collection 01" },
        "title": { "type": "string", "description": "Title of the showcase" },
        "description": { "type": "string", "description": "A poetic description or quote" },
        "imageUrl": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["collectionName", "title", "description", "imageUrl"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of luxury textiles"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "users": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "collections": {
      "schema": "Collection",
      "description": "Curated collections"
    },
    "testimonials": {
      "schema": "Testimonial",
      "description": "Customer testimonials"
    },
    "categories": {
      "schema": "Category",
      "description": "Product categories"
    },
    "user_activity": {
      "schema": "UserActivity",
      "description": "User browsing history and preferences"
    },
    "page_content": {
      "schema": "PageContent",
      "description": "Collection of page contents"
    },
    "hero_slides": {
      "schema": "HeroSlide",
      "description": "Images for the home page hero slider"
    },
    "collection_slides": {
      "schema": "CollectionSlide",
      "description": "Showcase slides for core collections"
    }
  }
}
