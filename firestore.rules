rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name, description, price, imageUrls, category, craftStory, materialDetails, careInstructions, createdAt
    //
    // Collection: orders
    // Fields: customerName, customerEmail, items, totalAmount, status, createdAt, uid
    //
    // Collection: users
    // Fields: email, role
    //
    // Collection: journal
    // Fields: title, date, imageUrl, excerpt, content, createdAt
    //
    // Collection: categories
    // Fields: name, description, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "betsiflash@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Products: Publicly readable, Publicly writable (for simple admin)
    match /products/{productId} {
      allow read, write: if true;
    }

    // Categories: Publicly readable, Publicly writable (for simple admin)
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    // Journal: Publicly readable, Publicly writable (for simple admin)
    match /journal/{articleId} {
      allow read, write: if true;
    }

    // Orders: Publicly readable, Publicly writable (for simple admin)
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Users: User can read/write their own, Admin can read/write all
    match /users/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }

    // Test Connection: Publicly readable for diagnostics
    match /test/connection {
      allow read: if true;
    }
  }
}
